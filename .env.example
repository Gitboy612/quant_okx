# QuantOKX 环境变量配置
# 复制为 .env 并修改对应值

# ===== 生产必填 =====
# JWT 密钥（生产环境务必修改为随机长字符串）
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# ===== 服务监听 =====
# 监听地址：127.0.0.1 仅本机访问；0.0.0.0 对外暴露（云服务器用）
HOST=127.0.0.1
# 监听端口
PORT=8000
# 生产模式标记
PRODUCTION=false

# ===== 跨域（可选）=====
# 同源托管时留空即可；如前端独立部署则填前端地址，多个用逗号分隔
# CORS_ORIGINS=https://example.com,http://localhost:5173

# ===== OKX API =====
OKX_BASE_URL=https://openapi.okx.com
# 备用接入点（逗号分隔）
OKX_ALT_URLS=https://www.okx.cab,https://aws.okx.com
# DNS 覆盖（格式 host:ip,host:ip）
# OKX_DNS_OVERRIDE=
# 外部代理（如系统已有 VPN，格式 http://127.0.0.1:7897）
# OKX_PROXY=
